<!DOCTYPE html>
<html>
<head>
  <%- include("../partials/header.ejs") %>
</head>

<body>

  <%- include("../partials/nav.ejs") %>

  <div class="jumbotron text-center">
    <div class="container">
      <a href="/" class="lang-logo">
        <img src="/lang-logo.png" alt="Node.js Logo">
      </a>

      <h1>Node.js App Running on Docker + EC2 🚀</h1>
      <p class="lead">
        This application is deployed using Docker, GitHub Actions CI/CD, and PostgreSQL database.
      </p>

      <hr>

      <!-- Signup Button -->
      <a href="/signup" class="btn btn-lg btn-primary">
        Signup
      </a>

      <!-- Login Button -->
      <a href="/login" class="btn btn-lg btn-success">
        Login
      </a>

      <!-- Users Button -->
      <a href="/users" class="btn btn-lg btn-info">
        View Users
      </a>

    </div>
  </div>

  <div class="container">

    <div class="row">

      <div class="col-md-4">
        <h3>Frontend</h3>
        <p>
          Running on Node.js Express and accessible via EC2 public IP.
        </p>
      </div>

      <div class="col-md-4">
        <h3>Backend</h3>
        <p>
          Express server handling routes, authentication, and API requests.
        </p>
      </div>

      <div class="col-md-4">
        <h3>Database</h3>
        <p>
          PostgreSQL running in Docker container and connected internally.
        </p>
      </div>

    </div>

    <hr>

    <div class="alert alert-success text-center">
      Your DevOps 3-Tier Architecture is working successfully 🎉
    </div>

  </div>

</body>
</html>
